# Force GitHub to detect HTML and CSS as primary languages
*.html linguist-detectable=true
*.css linguist-detectable=true

# Mark other folders as generated/vendored so they don't dominate the stats
src/** linguist-generated=true
backend-spring/** linguist-generated=true
node_modules/** linguist-generated=true
dist/** linguist-generated=true
.gemini/** linguist-generated=true
