# =============================================================================
# Frontend env vars (Vite)
# =============================================================================
# Copy this file to `.env.local` (gitignored) and adjust values for your
# environment. Vite picks up VITE_* variables automatically at build/dev time.
# =============================================================================

# Public base URL embedded inside donor-generated QR codes (Phase 12).
#
# When the donor's dashboard runs at http://localhost:5173, window.location.origin
# is "localhost" — which a phone scanning the QR cannot reach. Set this to a
# host the phone CAN reach: the LAN IP in dev, or your real domain in prod.
#
# Examples:
#   Dev (mobile on the same WiFi):  VITE_PUBLIC_BASE_URL=http://192.168.1.17:5173
#   Prod:                           VITE_PUBLIC_BASE_URL=https://lifeflow.example.com
#
# If unset, the frontend uses window.location.origin and shows a warning toast
# when the user generates a QR while on localhost.
VITE_PUBLIC_BASE_URL=

# Optional override for the backend API base. Default is the relative path
# `/api` which works through Vite's dev proxy (vite.config.ts) and in the
# Spring-Boot-merged deploy. Override only if the frontend is served
# separately from the backend.
# VITE_API_BASE_URL=/api
