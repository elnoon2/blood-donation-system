# Frontend production env vars (copy → .env.production, set per-environment).
# Used by Vite at build time. NEVER put secrets here — only public-safe values.

# Backend API base URL. With the vercel.json rewrite in place this can stay
# as "/api" (relative) so the Vercel edge proxies to Railway. If you'd rather
# call Railway directly from the browser, set the full URL and remove the
# rewrite from vercel.json.
VITE_API_BASE_URL=/api

# Public base URL embedded in donor QR codes. In prod this is your Vercel URL.
VITE_PUBLIC_BASE_URL=https://blood-donation-system-orpin.vercel.app
